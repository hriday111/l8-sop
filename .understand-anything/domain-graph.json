  "project": {
    "name": "sop-mag",
    "languages": [
      "c"
    ],
    "frameworks": [],
    "description": "UDP spell-casting game server where clients send fixed 16-byte messages to log in, cast spells on an 8×8 board, or quit; valid casts are processed asynchronously by worker threads.",
    "analyzedAt": "2026-05-25T22:08:56Z",
