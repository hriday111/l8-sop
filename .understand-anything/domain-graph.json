  },
  "nodes": [
    {
      "id": "domain:server-lifecycle",
      "type": "domain",
      "name": "Server Lifecycle",
      "summary": "Covers how the sop-mag process starts, binds a UDP listening socket on a CLI-provided port, runs the message loop, and shuts down cleanly.",
      "tags": [
        "startup",
        "udp",
        "cli"
      ],
      "complexity": "simple",
      "domainMeta": {
        "entities": [
          "UDP socket",
          "port argument"
        ],
        "businessRules": [
          "Exactly one port argument required",
          "Socket must bind before accepting messages"
        ],
        "crossDomainInteractions": [
          "Hosts the shared recvfrom loop used by player and spell domains"
        ]
      }
    },
    {
      "id": "domain:player-session",
      "type": "domain",
      "name": "Player Session",
      "summary": "Handles player identity via login messages and session termination via quit messages over the UDP protocol.",
      "tags": [
        "login",
        "session",
        "protocol"
      ],
      "complexity": "simple",
      "domainMeta": {
        "entities": [
          "login_message_t",
          "quit_message_t",
          "player name"
        ],
        "businessRules": [
          "Login packets must be exactly 16 bytes",
          "Player name is null-terminated before display",
          "Server accepts up to 5 total messages per run"
        ],
        "crossDomainInteractions": [
          "Shares doServer message loop with spell casting"
        ]
      }
    },
    {
      "id": "domain:spell-casting",
      "type": "domain",
      "name": "Spell Casting",
      "summary": "Validates incoming cast messages (spell type and board coordinates) and hands off successful casts to the async processing pipeline.",
      "tags": [
        "spells",
        "validation",
        "board"
      ],
      "complexity": "moderate",
      "domainMeta": {
        "entities": [
          "cast_message_t",
          "spell_names",
          "8×8 board"
        ],
        "businessRules": [
          "Spell id must be 0–2 (Divination, Summon Elemental, Fireball)",
          "X and Y must be < BOARD_SIZE (8)",
          "Cast fields arrive in network byte order"
        ],
        "crossDomainInteractions": [
          "Enqueues valid casts to the async cast delivery domain"
        ]
      }
    },
    {
      "id": "domain:async-cast-delivery",
      "type": "domain",
      "name": "Async Cast Delivery",
      "summary": "Three pthread workers consume cast messages from a mutex-protected circular queue signaled by a semaphore, printing spell results without blocking the UDP receive loop.",
      "tags": [
        "pthread",
        "queue",
        "async"
      ],
      "complexity": "moderate",
      "domainMeta": {
        "entities": [
          "queue_t",
          "worker threads",
          "cast_message_t buffer"
        ],
        "businessRules": [
          "Queue capacity MAX_QUEUE (10)",
          "THREAD_COUNT (3) workers",
          "queue_push only when count < MAX_QUEUE"
        ],
        "crossDomainInteractions": [
          "Receives validated casts from spell-casting domain"
        ]
      }
    },
